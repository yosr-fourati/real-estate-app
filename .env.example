# Database (Supabase PostgreSQL or any PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin credentials (stored in DB after seed, but used as defaults)
ADMIN_EMAIL="emailexample@gmail.com"
ADMIN_PASSWORD="password"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: WhatsApp contact number
NEXT_PUBLIC_WHATSAPP_NUMBER="21626454266"
